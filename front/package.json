    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.8",
    "eslint-plugin-svelte": "^3.15.2",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "sass": "^1.98.0",
    "svelte": "5.53.5",
    "svelte-check": "^4.4.5",
