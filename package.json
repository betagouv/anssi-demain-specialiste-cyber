{
  "name": "anssi-demain-specialiste-cyber",
  "version": "2.0.0",
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/betagouv/anssi-demain-specialiste-cyber.git"
  },
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "pnpm -r dev",
    "dev:front": "pnpm --filter anssi-demain-specialiste-cyber-front dev",
    "dev:back": "pnpm --filter anssi-demain-specialiste-cyber-back dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "migre-bdd": "pnpm --filter anssi-demain-specialiste-cyber-back migre-bdd",
    "start": "pnpm --filter anssi-demain-specialiste-cyber-back start ",
    "test": "pnpm -r test",
    "test:ci": "pnpm -r test:ci",
    "typecheck": "pnpm -r typecheck",
    "admin": "node -e \"const admin = new (require('./back/dist/src/admin/consoleAdministration.js').ConsoleAdministration)()\" -i",
    "admin:dev": "pnpm build -w back && node --env-file back/.env -e \"const admin = new (require('./back/dist/src/admin/consoleAdministration.js').ConsoleAdministration)()\" -i",
    "preinstall": "npx only-allow@1.2.2 pnpm"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.3",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "zod": "^4.3.6"
  },
  "private": true,
  "pnpm": {
    "overrides": {
      "qs": "~6.14.2",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "diff@>=4.0.0 <4.0.4": ">=4.0.4",
      "fast-xml-parser": "~5.3.8",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "ajv@<6.14.0": "6.14.0",
      "svelte@<=5.53.4": "5.53.5",
      "multer@<2.1.1": ">=2.1.1"
    }
  }
}
